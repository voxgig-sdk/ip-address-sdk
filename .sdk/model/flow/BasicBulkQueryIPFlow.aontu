  kind: "basic",
  name: "BasicBulkQueryIPFlow",
  step: [
    {
      match: {
        ips: "ips01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "bulk_query_i_p_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicBulkQueryIPFlow"
}